{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["xrm", "jest", "node", "react", "react-dom"]
  },
  "include": ["shared", "clientui", "clienthooks", "tests", ".storybook"],
  "exclude": ["node_modules", "dist", "pcfs", "storybook-static"]
}
