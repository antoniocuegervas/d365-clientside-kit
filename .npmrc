# Pin exact versions on install, so a later `npm install <pkg>` cannot reintroduce
# a caret range and let the dependency tree drift from the tested one. Consumers
# typically run `npm install`, not `npm ci`, so a caret would let them resolve a
# tree that was never tested here. Deliberately NOT setting engine-strict: the
# engines bound stays advisory (a warning, not a hard failure) for casual clones
# on a nearby Node/npm.
save-exact=true
