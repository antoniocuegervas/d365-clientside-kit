{
  "webresources": [
    {
      "profile": "default",
      "root": "../dist/",
      "solution": "D365UIKit",
      "files": [
        {
          "uniquename": "{{prefix}}clientui.html",
          "file": "clientui/{{prefix}}clientui.html",
          "description": "Unified client UI shell (single HTML entry, ?app= selection)"
        },
        {
          "uniquename": "{{prefix}}clientui.js",
          "file": "clientui/{{prefix}}clientui.js",
          "description": "Client UI bundle, shell + registered apps"
        },
        {
          "uniquename": "{{prefix}}clienthooks.js",
          "file": "clienthooks/{{prefix}}clienthooks.js",
          "description": "CrmClientSide form/ribbon/grid hook library"
        }
      ]
    }
  ]
}
