<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="D365Kit" constructor="KitNativeLookup" version="1.1.3" display-name-key="Kit Example: Native Lookup" description-key="Native-parity single-record lookup, the kit SmartNativeLookup bound to a lookup column. See docs/adding-a-pcf.md." control-type="virtual" >
    <external-service-usage enabled="false">
    </external-service-usage>
    <!-- The bound lookup column, as a type-group so the control can bind to a
         single-target lookup AND to polymorphic Customer/Owner columns. The smart
         control resolves and switches targets from metadata; raw is LookupValue[]. -->
    <type-group name="lookups">
      <type>Lookup.Simple</type>
      <type>Lookup.Customer</type>
      <type>Lookup.Owner</type>
    </type-group>
    <property name="value" display-name-key="Value" description-key="The bound lookup column rendered with the kit native-parity lookup" of-type-group="lookups" usage="bound" required="true" />
    <!-- Optional override for the bound column's logical name. The control reads
         it from the documented bound-property metadata (parameters.value
         .attributes.LogicalName) by default; this override exists for hosts or
         harnesses that do not populate that surface. -->
    <property name="attribute" display-name-key="Lookup column logical name (optional)" description-key="Override for the bound lookup column logical name; by default it is read from the bound property attribute metadata" of-type="SingleLine.Text" usage="input" required="false" />
    <!-- Optional: override the lookup view that drives the flyout columns and search.
         Omitted, the entity's default lookup view (querytype 64) is used. -->
    <property name="viewName" display-name-key="Lookup view name (optional)" description-key="Override the lookup view that drives the flyout columns and search; default is the entity lookup view" of-type="SingleLine.Text" usage="input" required="false" />
    <!-- Optional: show the target entity icon in the flyout rows (an extra metadata read). -->
    <property name="showIcons" display-name-key="Show entity icons" description-key="Resolve and show the target entity icon in the flyout rows" of-type="TwoOptions" usage="input" required="false" />
    <resources>
      <code path="index.ts" order="1"/>
      <!-- The platform hands the control its own React and Fluent at runtime.
           The declared versions are a compatibility floor, not the delivery:
           the org serves its current copies (and rejects imports declaring a
           version newer than it supports), so declare low and receive current.
           The icon package is not part of the platform Fluent library, so the
           icons the lookup renders stay in the bundle. -->
      <platform-library name="React" version="16.14.0" />
      <platform-library name="Fluent" version="9.46.2" />
    </resources>
    <feature-usage>
      <uses-feature name="Utility" required="true" />
      <uses-feature name="WebAPI" required="true" />
    </feature-usage>
  </control>
</manifest>
