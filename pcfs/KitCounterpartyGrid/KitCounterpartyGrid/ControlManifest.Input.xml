<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <!--
    The counterparty dataset PCF. A control bound to the account form's
    Activities subgrid. It renders the view's own columns plus two columns no
    native activitypointer-bound view can express: Counterparty (who is on the other
    end) and Role (their participationtypemask). The point of shipping it as a PCF
    is host placement: a PCF can BE the bound subgrid; a custom page cannot occupy
    that slot.

    control-type="virtual": the platform hands the control the host's own React
    and Fluent at runtime. The declared platform-library versions are a
    compatibility floor, not the delivery: the org serves its current copies
    (and rejects imports declaring a version newer than it supports), so declare
    low and receive current. The icon package is not part of the platform Fluent
    library, so the icons the grid renders stay in the bundle.
  -->
  <control namespace="D365Kit" constructor="KitCounterpartyGrid" version="0.1.4" display-name-key="Counterparty Activities" description-key="Cross-type activity grid with synthesized counterparty and role columns." control-type="virtual">
    <external-service-usage enabled="false">
    </external-service-usage>
    <!-- Bound to the account's Activities subgrid (activitypointer). -->
    <data-set name="activities" display-name-key="Activities">
    </data-set>
    <resources>
      <code path="index.ts" order="1"/>
      <platform-library name="React" version="16.14.0" />
      <platform-library name="Fluent" version="9.46.2" />
    </resources>
    <feature-usage>
      <uses-feature name="WebAPI" required="true" />
    </feature-usage>
  </control>
</manifest>
