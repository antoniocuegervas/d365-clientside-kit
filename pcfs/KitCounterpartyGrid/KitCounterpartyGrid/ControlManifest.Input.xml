<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <!--
    The counterparty dataset PCF. A control bound to the account form's
    Activities subgrid. It renders the view's own columns plus two columns no
    native activitypointer-bound view can express: Counterparty (who is on the other
    end) and Role (their participationtypemask). The point of shipping it as a PCF
    is host placement: a PCF can BE the bound subgrid; a custom page cannot occupy
    that slot.

    control-type="standard" and React + Fluent v9 are BUNDLED, not platform
    libraries. The platform-library mechanism does expose Fluent v9, but PINNED at
    9.46.2; this kit is on 9.74.1, so the platform copy cannot satisfy it and a
    virtual control renders to nothing. Bundling React 18 + Fluent v9 (the same as
    the kit's other PCFs) is the working path. The cost is bundle size, accepted.
    See the decision-log note.
  -->
  <control namespace="D365Kit" constructor="KitCounterpartyGrid" version="0.0.17" display-name-key="Counterparty Activities" description-key="Cross-type activity grid with synthesized counterparty and role columns." control-type="standard">
    <external-service-usage enabled="false">
    </external-service-usage>
    <!-- Bound to the account's Activities subgrid (activitypointer). -->
    <data-set name="activities" display-name-key="Activities">
    </data-set>
    <resources>
      <code path="index.ts" order="1"/>
    </resources>
    <feature-usage>
      <uses-feature name="WebAPI" required="true" />
    </feature-usage>
  </control>
</manifest>
