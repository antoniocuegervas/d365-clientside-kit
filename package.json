{
  "name": "d365-clientside-kit",
  "version": "1.0.3",
  "private": true,
  "description": "Dynamics 365 / Dataverse client-side UI kit, metadata-aware React building blocks with refreshed-UCI (Fluent v9) fidelity. Spiritual successor to SparkleXrm.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "test": "jest --testPathIgnorePatterns tests/smoke",
    "coverage": "jest --testPathIgnorePatterns tests/smoke --coverage",
    "smoke": "jest tests/smoke",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "verify": "npm run lint && npm run typecheck && npm run build && npm run test && npm run smoke && npm run build-storybook"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.74.1",
    "@fluentui/react-datepicker-compat": "^0.6.32",
    "@fluentui/react-icons": "^2.0.329",
    "@fluentui/react-timepicker-compat": "^0.4.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/xrm": "^9.0.94",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "storybook": "^10.4.4",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  }
}
